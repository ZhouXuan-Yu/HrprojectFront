# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Mock fallback — when false (default), DB errors surface as real errors
# Set to true only in dev when the database is unavailable
MOCK_FALLBACK=false

# Database
DATABASE_URL=sqlite:///hr_recruit.db
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/hr_recruit

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=86400

# DeepSeek AI — required, no default
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Feishu (leave empty to use mock fallback)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# IAM Sync
IAM_DB_URL=

# CORS
CORS_ORIGINS=http://127.0.0.1:5173

# Boss CLI
BOSS_CLI_ENABLED=true
BOSS_CLI_TIMEOUT=120
